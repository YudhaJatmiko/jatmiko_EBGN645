G e n e r a l   A l g e b r a i c   M o d e l i n g   S y s t e m
C o m p i l a t i o n


   1  *Hotelling Model for Nickel Extraction
   2   
   3  Sets
   4  t 'time period' /1*30/
   5  countries 'nickel production per country' /us, australia, brazil, canada, china, indonesia, newcaledonia, philippines, russia, other/
   6  scenario 'price scenarios' /oversupply, balanced, supply_constraint, ev_boom/
   7  ;
   8   
   9  *production and reserve data
  10  table prod_reserve(countries,*)
  11                   prod2022  prod2023  reserves
  12  us                 17500     17000    340000
  13  australia         155000    160000  24000000
  14  brazil             88500     89000  16000000
  15  canada            143000    180000   2200000
  16  china             114000    110000   4200000
  17  indonesia        1580000   1800000  55000000
  18  newcaledonia      200000    230000   7100000
  19  philippines       345000    400000   4800000
  20  russia            222000    200000   8300000
  21  other             404000    380000   9100000
  22  ;
  23   
  24  *parameter declaration
  25  parameter
  26  p0 'initial nickel price (USD per tonne)'
  27  r0 'total initial reserves (tonnes)'
  28  q0 'initial monthly extraction rate (tonnes)'
  29  c 'extraction cost (USD per tonne)'
  30  disc_rate 'discount rate'
  31  disc(t) 'discount factor by period'
  32  ;
  33   
  34  *assumptions
  35  *cost assumption: 1000 USD per tonne
  36  *discount rate: 5% per period
  37  *initial price: latest nickel price from June 2025 data
  38  p0 = 15003.11;
  39  r0 = sum(countries, prod_reserve(countries,'reserves'));
  40  q0 = sum(countries, prod_reserve(countries,'prod2023')) / 12;
  41  c = 1000;
  42  disc_rate = 0.05;
  43   
  44  *discount factor calculation
  45  disc(t) = 1 / power(1 + disc_rate, ord(t) - 1);
  46  display p0, r0, q0;
  47   
  48  *new parameter (indonesia and scenarios)
  49  parameter
  50  r0_INA 'Indonesian reserves only'
  51  q0_INA 'Indonesian annual production'
  52  growth_rate(scenario) 'annual price growth rates'
  53  prob_scenario(scenario) 'scenario probabilities'
  54  price_path(scenario,t) 'price evolution by scenario'
  55  ;
  56   
  57  *Indonesia specific parameters
  58  r0_INA = prod_reserve('indonesia','reserves');
  59  q0_INA = prod_reserve('indonesia','prod2023');
  60   
  61   
  62  *price scenario (based on IEA mineral outlook), I dont find nickel price forecast
  63  growth_rate('oversupply') = -0.03;
  64  growth_rate('balanced') = 0.02;
  65  growth_rate('supply_constraint') = 0.04;
  66  growth_rate('ev_boom') = 0.06;
  67   
  68  *probability of scenario
  69  prob_scenario('oversupply') = 0.25;
  70  prob_scenario('balanced') = 0.40;
  71  prob_scenario('supply_constraint') = 0.20;
  72  prob_scenario('ev_boom') = 0.15;
  73   
  74  *price path based on the scenario
  75  price_path(scenario,t) = p0 * power(1 + growth_rate(scenario), ord(t) - 1);
  76   
  77   
  78  *variables
  79  positive variable
  80  q(t) 'quantity of extraction in period t (tonnes)'
  81  reserve(t) 'remaining reserves by the end of period t (tonnes)'
  82  *Indonesia focus variables
  83  q_INA(scenario,t) 'Indonesian extraction by scenario'
  84  reserve_INA(scenario,t) 'Indonesian reserves by scenario'
  85  ;
  86   
  87  free variable
  88  NPV 'net present value (USD)'
  89  NPV_INA(scenario) 'Indonesian NPV by scenario'
  90  expected_NPV_INA 'expected Indonesian NPV'
  91  ;
  92   
  93   
  94  *equations
  95  equations
  96  obj 'objective function - maximize NPV'
  97  res_init 'initial reserve constraint'
  98  res_bal(t) 'reserve balance equation'
  99  *Indonesia Equations
 100  obj_INA(scenario) 'Indonesian NPV by scenario'
 101  exp_obj_INA 'expected Indonesian NPV'
 102  res_init_INA(scenario) 'Indonesian initial reserves'
 103  res_bal_INA(scenario,t) 'Indonesian reserve balance'
 104  ;
 105   
 106   
 107  *NPV maximization objective function
 108  obj.. NPV =e= sum(t, disc(t) * (p0 * q(t) - c * q(t)));
 109   
 110  *initial reserve constraint
 111  res_init.. reserve('1') =e= r0 - q('1');
 112   
 113  *reserve balance equation
 114  res_bal(t)$(ord(t) > 1).. reserve(t) =e= reserve(t-1) - q(t);
 115   
 116   
 117  *Indonesia scenario
 118  obj_INA(scenario).. NPV_INA(scenario) =e= sum(t, disc(t) * (price_path(scenario,t) - c) * q_INA(scenario,t));
 119  exp_obj_INA.. expected_NPV_INA =e= sum(scenario, prob_scenario(scenario) * NPV_INA(scenario));
 120  res_init_INA(scenario).. reserve_INA(scenario,'1') =e= r0_INA - q_INA(scenario,'1');
 121  res_bal_INA(scenario,t)$(ord(t) > 1).. reserve_INA(scenario,t) =e= reserve_INA(scenario,t-1) - q_INA(scenario,t);
 122   
 123   
 124  *bounds and initial values
 125  q.lo(t) = 0;
 126  q.up(t) = q0 * 2;
 127  q.l(t) = q0;
 128  reserve.lo(t) = 0;
 129  reserve.l(t) = r0 - q0 * ord(t);
 130   
 131  *Indonesian bounds
 132  q_INA.lo(scenario,t) = 0;
 133  q_INA.up(scenario,t) = q0_INA * 2;
 134  q_INA.l(scenario,t) = q0_INA;
 135  reserve_INA.lo(scenario,t) = 0;
 136  reserve_INA.l(scenario,t) = r0_INA - q0_INA * ord(t);
 137   
 138  *solve model
 139  model hotelling /all/;
 140  solve hotelling using nlp maximizing NPV;
 141   
 142  *solve indonesia model
 143  model hotelling_INA /obj_INA, exp_obj_INA, res_init_INA, res_bal_INA/;
 144  solve hotelling_INA using nlp maximizing expected_NPV_INA;
 145   
 146  *post-processing calculations
 147  alias(t, t_prev);
 148   
 149  parameter
 150  cum_extraction(t) 'cumulative extraction by period t (tonnes)'
 151  depletion 'percentage of reserves depleted (%)'
 152  ;
 153   
 154  *Indonesia analysis
 155  parameter
 156  early_extraction_INA(scenario) 'Indonesian extraction years 1-10'
 157  late_extraction_INA(scenario) 'Indonesian extraction years 11-20'
 158  timing_ratio(scenario) 'early vs late extraction ratio'
 159  final_price(scenario) 'price in year 30'
 160  ;
 161   
 162   
 163  cum_extraction(t) = sum(t_prev$(ord(t_prev) <= ord(t)), q.l(t_prev));
 164  depletion = 100 * sum(t, q.l(t)) / r0;
 165  *new timing
 166  early_extraction_INA(scenario) = sum(t$(ord(t) <= 10), q_INA.l(scenario,t));
 167  late_extraction_INA(scenario) = sum(t$(ord(t) >= 11), q_INA.l(scenario,t));
 168  timing_ratio(scenario) = early_extraction_INA(scenario) / (late_extraction_INA(scenario) + 0.001);
 169  final_price(scenario) = price_path(scenario,'30');
 170   
 171   
 172  *display results
 173  display
 174  hotelling.modelstat, hotelling.solvestat,
 175  NPV.l, q.l, reserve.l, cum_extraction, depletion,
 176  expected_NPV_INA.l,
 177  NPV_INA.l,
 178  timing_ratio,
 179  final_price
 180  ;
 181   
 182   
 183  *export results
 184  execute_unload "result_global.gdx";
 185  execute_unload "indonesia_results.gdx" q_INA, NPV_INA, timing_ratio;
 186   
